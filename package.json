{
  "name": "poke-mate",
  "private": true,
  "version": "0.0.0",
  "description": "Pokémon Champions 対戦研究ノート — GUI + MCP + Claude Skills",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/** build && pnpm -r --filter=./apps/** build",
    "dev": "pnpm -r --parallel --filter=./apps/** dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
